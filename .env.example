# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env

# Conexao com banco de dados PostgreSQL
# Os dados de participantes (nome, email, redes sociais) sao armazenados
# sob as obrigacoes da LGPD (Lei 13.709/2018)
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require&channel_binding=require

# Porta do servidor HTTP (padrao: 3000)
PORT=3000

# Dominio para HTTPS automatico (Let's Encrypt)
# Deixe vazio para rodar em HTTP local (desenvolvimento)
# Com dominio: app sobe em :443 com certificado automatico + redireciona :80 para HTTPS
DOMAIN=seuevento.com.br

# Chave de acesso para o endpoint de exclusao de dados (LGPD art. 18)
# Gere uma chave forte: openssl rand -hex 32
# Sem esta variavel o endpoint DELETE /api/dados/:email fica desabilitado
ADMIN_KEY=troque_por_uma_chave_forte
